{
  "name": "crp-scan",
  "displayName": "CRP Scan",
  "description": "AI Governance Scanner for VS Code — detects ungoverned LLM calls and missing safety policies",
  "version": "0.3.0",
  "publisher": "autocyber-ai",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AutoCyber-AI/crp-scan.git"
  },
  "homepage": "https://crprotocol.io",
  "bugs": {
    "url": "https://github.com/AutoCyber-AI/crp-scan/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Linters",
    "Machine Learning",
    "Testing"
  ],
  "keywords": [
    "ai governance",
    "compliance",
    "eu ai act",
    "llm safety",
    "crp"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:java",
    "onLanguage:go",
    "onLanguage:rust",
    "onCommand:crpScan.scanWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crpScan.scanWorkspace",
        "title": "CRP: Scan Workspace",
        "icon": "$(shield)"
      },
      {
        "command": "crpScan.openRemediationPR",
        "title": "CRP: Open Remediation PR",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "crpScan.showSettings",
        "title": "CRP: Open Settings"
      },
      {
        "command": "crpScan.showScanOutput",
        "title": "CRP: Show Last Scan Output"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "crpScan.scanWorkspace",
          "group": "2_workspace@5",
          "when": "explorerResourceIsFolder"
        }
      ],
      "commandPalette": [
        {
          "command": "crpScan.scanWorkspace"
        },
        {
          "command": "crpScan.openRemediationPR"
        },
        {
          "command": "crpScan.showScanOutput"
        }
      ]
    },
    "configuration": {
      "title": "CRP Scan",
      "properties": {
        "crpScan.failOn": {
          "type": "string",
          "default": "HIGH",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ],
          "description": "Minimum severity that causes a diagnostic error"
        },
        "crpScan.paths": {
          "type": "string",
          "default": ".",
          "description": "Comma-separated paths to scan relative to workspace root"
        },
        "crpScan.autoScanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the workspace when a file is saved"
        },
        "crpScan.autoScanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the workspace when a folder is opened"
        },
        "crpScan.minVersion": {
          "type": "string",
          "default": "",
          "description": "Minimum crprotocol version to enforce (e.g. 4.0.0)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/vscode": "^1.120.0",
    "typescript": "^5.3.0"
  }
}
